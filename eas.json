{
  "cli": {
    "version": ">= 16.30.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "installCommand": "npm install --include=dev"
    },
    "preview": {
      "distribution": "internal",
      "installCommand": "npm install --include=dev"
    },
    "production": {
      "autoIncrement": true,
      "cache": {
        "disabled": true
      },
      "installCommand": "npm install --include=dev"
    }
  },
  "submit": {
    "production": {}
  }
}
